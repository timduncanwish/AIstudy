# AI助学 后端环境变量示例
# 复制为 .env 并填入真实值；.env 不入库

# ===== 智谱AI（必填，否则 AI 对话/批改/出题不可用）=====
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-4-flash
ZHIPU_EMBEDDING_MODEL=embedding-3

# ===== 数据库 =====
# 开发用 SQLite；生产可换 MySQL，如 mysql+aiomysql://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./ai_tutor.db
CHROMA_PERSIST_DIR=./chroma_data

# ===== 服务 =====
APP_HOST=0.0.0.0
APP_PORT=8000
# 生产务必设为 false
DEBUG=true

# CORS 允许来源，逗号分隔；默认 * 仅适合开发，生产应填具体域名
# 例：ALLOWED_ORIGINS=https://your-h5-domain.com,https://servicewechat.com
ALLOWED_ORIGINS=*

# ===== 安全（生产必设）=====
# 强随机字符串；不设则用公开默认值，登录令牌可被伪造！
JWT_SECRET=change_me_to_a_strong_random_secret

# ===== 微信小程序 =====
WX_APPID=
WX_SECRET=
# 订阅消息模板 ID（在小程序后台申请后填入）
WX_TMPL_PRACTICE=
WX_TMPL_DAILY=
